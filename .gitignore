    Thumbs.db
.DS_Store

# =========================================================================
# Future Judge Execution Engine Sandbox Artifacts
# =========================================================================
# If your local worker processes write temp user code files to disk 
# during development, this prevents committing submissions to GitHub.
*.tmp
*.class
*.exe
*.o