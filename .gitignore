# =========================================================================
# Spring Boot & Build Tools Core
# =========================================================================
target/
build/
.gradle/
.mvn/wrapper/maven-wrapper.jar

# Keep tracking source files even if directory names contain target/build flags
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# =========================================================================
# System Security & Local Configurations (Crucial for microservices)
# =========================================================================
.env
*.local
src/main/resources/application-local.yml
src/main/resources/application-local.properties

